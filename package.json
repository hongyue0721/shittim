{
  "name": "shittim",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.3.0"
  },
  "scripts": {
    "check:toolchain": "node scripts/check-node-toolchain.mjs",
    "check:file-manifest": "node scripts/update-file-manifest.mjs --check",
    "write:file-manifest": "node scripts/update-file-manifest.mjs --write",
    "test:file-manifest": "node scripts/update-file-manifest.mjs --self-test",
    "check:docs-repository": "node scripts/sync-docs-repository.mjs --check",
    "sync:docs-repository": "node scripts/sync-docs-repository.mjs --sync",
    "test:docs-repository": "node --test scripts/sync-docs-repository.test.mjs"
  }
}
