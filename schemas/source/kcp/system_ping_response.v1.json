{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/v1/kcp/system_ping_response.json",
  "title": "SystemPingResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "echo", "kernel_time", "protocol_version"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "echo": {
      "type": ["string", "null"]
    },
    "kernel_time": {
      "type": "string",
      "format": "date-time"
    },
    "protocol_version": {
      "type": "string",
      "const": "1.0"
    }
  }
}
