{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/kcp/task_create_response/v2",
  "title": "TaskCreateResponseV2",
  "description": "Active task.create response payload. task uses current active retained TaskSpec v1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task",
    "creation_provenance_ref"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "task": {
      "$ref": "https://schemas.shittim.local/v1/task/task_spec.json"
    },
    "creation_provenance_ref": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    }
  }
}
