{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/v1/kcp/query_envelope.json",
  "title": "KcpQueryEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "message_kind",
    "request_id",
    "actor",
    "entry_point",
    "auth",
    "task_id",
    "deadline",
    "query_type",
    "payload"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "const": "1.0"
    },
    "message_kind": {
      "type": "string",
      "const": "query"
    },
    "request_id": {
      "type": "string",
      "format": "uuid"
    },
    "actor": {
      "$ref": "https://schemas.shittim.local/v1/common/actor.json"
    },
    "entry_point": {
      "$ref": "https://schemas.shittim.local/v1/common/entry_point.json"
    },
    "auth": {
      "type": "null"
    },
    "task_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "deadline": {
      "type": "string",
      "format": "date-time"
    },
    "query_type": {
      "type": "string",
      "enum": [
        "system.ping",
        "task.get",
        "task.list",
        "event.subscribe",
        "event.poll",
        "stop.status"
      ]
    },
    "payload": {
      "type": "object",
      "required": ["schema_version"],
      "properties": {
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "query_type": { "const": "system.ping" }
        },
        "required": ["query_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "https://schemas.shittim.local/v1/kcp/system_ping_request.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query_type": { "const": "task.get" }
        },
        "required": ["query_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "https://schemas.shittim.local/v1/kcp/task_get_request.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query_type": { "const": "task.list" }
        },
        "required": ["query_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "https://schemas.shittim.local/v1/kcp/task_list_request.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query_type": { "const": "event.subscribe" }
        },
        "required": ["query_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "https://schemas.shittim.local/v1/kcp/event_subscribe_request.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query_type": { "const": "event.poll" }
        },
        "required": ["query_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "https://schemas.shittim.local/v1/kcp/event_poll_request.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query_type": { "const": "stop.status" }
        },
        "required": ["query_type"]
      },
      "then": {
        "properties": {
          "payload": {
            "$ref": "https://schemas.shittim.local/v1/kcp/stop_status_request.json"
          }
        }
      }
    }
  ]
}
