{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/v1/kcp/event_poll_request.json",
  "title": "EventPollRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "subscription_id",
    "after_outbox_position",
    "limit"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "subscription_id": {
      "type": "string",
      "format": "uuid"
    },
    "after_outbox_position": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500
    }
  }
}
