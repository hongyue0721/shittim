{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/audit/audit_allocation/v2",
  "title": "AuditAllocationV2",
  "description": "Required allocation object for an independent AuditRecord v2 write path.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_record_id",
    "correlation_id",
    "occurred_at",
    "causation_ref"
  ],
  "properties": {
    "audit_record_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "causation_ref": {
      "$ref": "https://schemas.shittim.local/common/causation_ref/v2"
    }
  }
}
