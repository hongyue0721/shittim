{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/common/causation_ref/v2",
  "title": "CausationRefV2",
  "description": "Active closed causation union: command_request | event | action | action_transition.",
  "type": "object",
  "required": [
    "kind"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "command_request",
        "event",
        "action",
        "action_transition"
      ]
    }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "command_request"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "event"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "action"
        },
        "id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    {
      "$ref": "https://schemas.shittim.local/common/action_transition_ref/v1"
    }
  ],
  "unevaluatedProperties": false
}
