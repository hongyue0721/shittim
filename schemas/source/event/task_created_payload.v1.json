{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/v1/event/task_created_payload.json",
  "title": "TaskCreatedPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "status",
    "proposer",
    "goal",
    "task_revision",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "task_id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "$ref": "https://schemas.shittim.local/v1/common/task_status.json"
    },
    "proposer": {
      "type": "string",
      "enum": ["user", "companion", "system"]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "task_revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
