{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/event/action_state_changed_payload/v1",
  "title": "ActionStateChangedPayloadV1",
  "description": "Complete Action state-change snapshot projected by the owning repository.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "action_id",
    "task_id",
    "from_status",
    "to_status",
    "action_revision",
    "execution_generation",
    "permission_decision_ref",
    "approval_resolution_ref",
    "materialized_child_task_ref",
    "verification_result_refs",
    "reason_code",
    "changed_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "action_id": {
      "type": "string",
      "format": "uuid"
    },
    "task_id": {
      "type": "string",
      "format": "uuid"
    },
    "from_status": {
      "$ref": "https://schemas.shittim.local/v1/common/action_status.json"
    },
    "to_status": {
      "$ref": "https://schemas.shittim.local/v1/common/action_status.json"
    },
    "action_revision": {
      "type": "integer",
      "minimum": 1
    },
    "execution_generation": {
      "type": "integer",
      "minimum": 0
    },
    "permission_decision_ref": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "approval_resolution_ref": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "materialized_child_task_ref": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "verification_result_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "reason_code": {
      "type": "string",
      "minLength": 1
    },
    "changed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "to_status": {
            "enum": [
              "completed",
              "failed"
            ]
          }
        },
        "required": [
          "to_status"
        ]
      },
      "then": {
        "properties": {
          "verification_result_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "materialized_child_task_ref": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "materialized_child_task_ref"
        ]
      },
      "then": {
        "properties": {
          "to_status": {
            "const": "completed"
          },
          "verification_result_refs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "format": "uuid"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "approval_resolution_ref": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "approval_resolution_ref"
        ]
      },
      "then": {
        "properties": {
          "permission_decision_ref": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    }
  ]
}
