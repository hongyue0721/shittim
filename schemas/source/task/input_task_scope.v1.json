{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/task/input_task_scope/v1",
  "title": "InputTaskScopeV1",
  "description": "Caller-declarable task scope input. Stored TaskScope identity/time fields are forbidden.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "resource_patterns",
    "exclusions",
    "allowed_capability_hints",
    "expires_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "resource_patterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "exclusions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_capability_hints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-5][0-9](?:\\.0+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    }
  }
}
