{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/policy/credential_ref/v1",
  "title": "CredentialRefV1",
  "description": "Immutable snapshot reference to a registered remote-signature credential revision used by challenges and responses.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "credential_id",
    "credential_revision",
    "actor_ref",
    "issuer_ref",
    "signature_algorithm",
    "not_before",
    "expires_at",
    "status",
    "replaced_by_ref"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "credential_id": {
      "$ref": "#/$defs/uuid"
    },
    "credential_revision": {
      "type": "integer",
      "minimum": 1
    },
    "actor_ref": {
      "type": "string",
      "minLength": 1
    },
    "issuer_ref": {
      "type": "string",
      "minLength": 1
    },
    "signature_algorithm": {
      "$ref": "https://schemas.shittim.local/policy/remote_signature_algorithm/v1"
    },
    "not_before": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["active", "revoked", "expired"]
    },
    "replaced_by_ref": {
      "$ref": "#/$defs/nullable_uuid"
    }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "nullable_uuid": {
      "type": ["string", "null"],
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    }
  }
}
