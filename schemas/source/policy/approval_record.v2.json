{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/policy/approval_record/v2",
  "title": "ApprovalRecordV2",
  "description": "Immutable Approval chain record. Both record_kind and subject.subject_kind are closed tagged unions.",
  "type": "object",
  "required": [
    "id",
    "schema_version",
    "approval_chain_id",
    "predecessor_ref",
    "record_kind",
    "subject",
    "created_at",
    "expires_at",
    "record"
  ],
  "properties": {
    "id": {
      "$ref": "#/$defs/uuid"
    },
    "schema_version": {
      "type": "integer",
      "const": 2
    },
    "approval_chain_id": {
      "$ref": "#/$defs/uuid"
    },
    "predecessor_ref": {
      "$ref": "#/$defs/nullable_uuid"
    },
    "record_kind": {
      "type": "string",
      "enum": [
        "request",
        "resolution",
        "invalidation"
      ]
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "record": true
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "schema_version",
        "approval_chain_id",
        "predecessor_ref",
        "record_kind",
        "subject",
        "created_at",
        "expires_at",
        "record"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/uuid"
        },
        "schema_version": {
          "type": "integer",
          "const": 2
        },
        "approval_chain_id": {
          "$ref": "#/$defs/uuid"
        },
        "predecessor_ref": {
          "$ref": "#/$defs/nullable_uuid"
        },
        "record_kind": {
          "type": "string",
          "const": "request"
        },
        "subject": {
          "$ref": "#/$defs/subject"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "record": {
          "$ref": "#/$defs/request_record"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "schema_version",
        "approval_chain_id",
        "predecessor_ref",
        "record_kind",
        "subject",
        "created_at",
        "expires_at",
        "record"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/uuid"
        },
        "schema_version": {
          "type": "integer",
          "const": 2
        },
        "approval_chain_id": {
          "$ref": "#/$defs/uuid"
        },
        "predecessor_ref": {
          "$ref": "#/$defs/uuid"
        },
        "record_kind": {
          "type": "string",
          "const": "resolution"
        },
        "subject": {
          "$ref": "#/$defs/subject"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "record": {
          "$ref": "#/$defs/resolution_record"
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "schema_version",
        "approval_chain_id",
        "predecessor_ref",
        "record_kind",
        "subject",
        "created_at",
        "expires_at",
        "record"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/uuid"
        },
        "schema_version": {
          "type": "integer",
          "const": 2
        },
        "approval_chain_id": {
          "$ref": "#/$defs/uuid"
        },
        "predecessor_ref": {
          "$ref": "#/$defs/uuid"
        },
        "record_kind": {
          "type": "string",
          "const": "invalidation"
        },
        "subject": {
          "$ref": "#/$defs/subject"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "null"
        },
        "record": {
          "$ref": "#/$defs/invalidation_record"
        }
      }
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "nullable_uuid": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "subject": {
      "type": "object",
      "required": [
        "subject_kind"
      ],
      "properties": {
        "subject_kind": {
          "type": "string",
          "enum": [
            "operation",
            "task_proposal",
            "plan_revision"
          ]
        }
      },
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "subject_kind",
            "task_id",
            "task_revision",
            "task_plan_version",
            "action_id",
            "action_revision",
            "permission_decision_ref",
            "permission_decision_revision",
            "policy_set_revision",
            "material_authorization_fingerprint",
            "capability_id",
            "operation",
            "side_effect_class",
            "resource_refs_hash",
            "key_params_hash"
          ],
          "properties": {
            "subject_kind": {
              "type": "string",
              "const": "operation"
            },
            "task_id": {
              "$ref": "#/$defs/uuid"
            },
            "task_revision": {
              "type": "integer",
              "minimum": 1
            },
            "task_plan_version": {
              "type": "integer",
              "minimum": 0
            },
            "action_id": {
              "$ref": "#/$defs/uuid"
            },
            "action_revision": {
              "type": "integer",
              "minimum": 1
            },
            "permission_decision_ref": {
              "$ref": "#/$defs/uuid"
            },
            "permission_decision_revision": {
              "type": "integer",
              "minimum": 1
            },
            "policy_set_revision": {
              "type": "integer",
              "minimum": 0
            },
            "material_authorization_fingerprint": {
              "$ref": "#/$defs/hash"
            },
            "capability_id": {
              "type": "string",
              "minLength": 1
            },
            "operation": {
              "type": "string",
              "minLength": 1
            },
            "side_effect_class": {
              "$ref": "https://schemas.shittim.local/v1/common/side_effect_class.json"
            },
            "resource_refs_hash": {
              "$ref": "#/$defs/hash"
            },
            "key_params_hash": {
              "$ref": "#/$defs/hash"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "subject_kind",
            "candidate_task_id",
            "candidate_revision",
            "proposal_hash",
            "proposer_actor_ref",
            "task_scope_hash",
            "delegation_ref",
            "policy_set_revision"
          ],
          "properties": {
            "subject_kind": {
              "type": "string",
              "const": "task_proposal"
            },
            "candidate_task_id": {
              "$ref": "#/$defs/uuid"
            },
            "candidate_revision": {
              "type": "integer",
              "minimum": 1
            },
            "proposal_hash": {
              "$ref": "#/$defs/hash"
            },
            "proposer_actor_ref": {
              "type": "string",
              "minLength": 1
            },
            "task_scope_hash": {
              "$ref": "#/$defs/hash"
            },
            "delegation_ref": {
              "$ref": "#/$defs/nullable_uuid"
            },
            "policy_set_revision": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "subject_kind",
            "task_id",
            "task_revision",
            "base_plan_version",
            "proposed_plan_version",
            "proposed_plan_hash",
            "policy_set_revision"
          ],
          "properties": {
            "subject_kind": {
              "type": "string",
              "const": "plan_revision"
            },
            "task_id": {
              "$ref": "#/$defs/uuid"
            },
            "task_revision": {
              "type": "integer",
              "minimum": 1
            },
            "base_plan_version": {
              "type": "integer",
              "minimum": 0
            },
            "proposed_plan_version": {
              "type": "integer",
              "minimum": 0
            },
            "proposed_plan_hash": {
              "$ref": "#/$defs/hash"
            },
            "policy_set_revision": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "invalidation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invalidated_record_ref",
        "reason_code",
        "invalidated_at",
        "invalidated_by_actor",
        "invalidated_from_entry_point",
        "replacement_request_ref"
      ],
      "properties": {
        "invalidated_record_ref": {
          "$ref": "#/$defs/uuid"
        },
        "reason_code": {
          "type": "string",
          "enum": [
            "material_changed",
            "subject_revision_changed",
            "policy_requirement_changed",
            "delegation_inactive",
            "credential_revoked",
            "evidence_expired",
            "approval_expired",
            "stop_fence_activated",
            "manual_revocation",
            "migration_quarantine"
          ]
        },
        "invalidated_at": {
          "type": "string",
          "format": "date-time"
        },
        "invalidated_by_actor": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "https://schemas.shittim.local/v1/common/actor.json"
            }
          ]
        },
        "invalidated_from_entry_point": {
          "$ref": "https://schemas.shittim.local/v1/common/entry_point.json"
        },
        "replacement_request_ref": {
          "$ref": "#/$defs/nullable_uuid"
        }
      }
    },
    "request_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_id",
        "confirmation_mode",
        "requested_by_actor",
        "requested_from_entry_point",
        "reason_codes",
        "challenge_ref",
        "request_expires_at"
      ],
      "properties": {
        "request_id": {
          "$ref": "#/$defs/uuid"
        },
        "confirmation_mode": {
          "$ref": "https://schemas.shittim.local/common/confirmation_mode/v1"
        },
        "requested_by_actor": {
          "$ref": "https://schemas.shittim.local/v1/common/actor.json"
        },
        "requested_from_entry_point": {
          "$ref": "https://schemas.shittim.local/v1/common/entry_point.json"
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "challenge_ref": {
          "$ref": "#/$defs/nullable_uuid"
        },
        "request_expires_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "confirmation_mode": {
                "enum": [
                  "remote_signature",
                  "system_authentication"
                ]
              }
            },
            "required": [
              "confirmation_mode"
            ]
          },
          "then": {
            "properties": {
              "challenge_ref": {
                "$ref": "#/$defs/uuid"
              }
            }
          },
          "else": {
            "properties": {
              "challenge_ref": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "resolution_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "request_ref",
        "decision",
        "resolved_by_actor",
        "resolved_from_entry_point",
        "resolved_at",
        "evidence_refs",
        "remote_response_ref",
        "local_presence_evidence_ref",
        "system_auth_evidence_ref"
      ],
      "properties": {
        "request_ref": {
          "$ref": "#/$defs/uuid"
        },
        "decision": {
          "type": "string",
          "enum": [
            "approved",
            "denied"
          ]
        },
        "resolved_by_actor": {
          "$ref": "https://schemas.shittim.local/v1/common/actor.json"
        },
        "resolved_from_entry_point": {
          "$ref": "https://schemas.shittim.local/v1/common/entry_point.json"
        },
        "resolved_at": {
          "type": "string",
          "format": "date-time"
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/uuid"
          }
        },
        "remote_response_ref": {
          "$ref": "#/$defs/nullable_uuid"
        },
        "local_presence_evidence_ref": {
          "$ref": "#/$defs/nullable_uuid"
        },
        "system_auth_evidence_ref": {
          "$ref": "#/$defs/nullable_uuid"
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "evidence_refs": {
                  "maxItems": 0
                },
                "remote_response_ref": {
                  "type": "null"
                },
                "local_presence_evidence_ref": {
                  "type": "null"
                },
                "system_auth_evidence_ref": {
                  "type": "null"
                }
              }
            },
            {
              "properties": {
                "evidence_refs": {
                  "minItems": 1,
                  "maxItems": 1
                },
                "remote_response_ref": {
                  "$ref": "#/$defs/uuid"
                },
                "local_presence_evidence_ref": {
                  "type": "null"
                },
                "system_auth_evidence_ref": {
                  "type": "null"
                }
              }
            },
            {
              "properties": {
                "evidence_refs": {
                  "minItems": 1,
                  "maxItems": 1
                },
                "remote_response_ref": {
                  "type": "null"
                },
                "local_presence_evidence_ref": {
                  "$ref": "#/$defs/uuid"
                },
                "system_auth_evidence_ref": {
                  "type": "null"
                }
              }
            },
            {
              "properties": {
                "evidence_refs": {
                  "minItems": 1,
                  "maxItems": 1
                },
                "remote_response_ref": {
                  "type": "null"
                },
                "local_presence_evidence_ref": {
                  "type": "null"
                },
                "system_auth_evidence_ref": {
                  "$ref": "#/$defs/uuid"
                }
              }
            }
          ]
        }
      ]
    }
  }
}
