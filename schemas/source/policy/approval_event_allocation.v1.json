{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.shittim.local/policy/approval_event_allocation/v1",
  "title": "ApprovalEventAllocationV1",
  "description": "Required caller allocation for one committed Approval current-head mutation and its single approval.state_changed event.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "correlation_id",
    "dedup_key",
    "changed_at",
    "causation_ref"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "correlation_id": { "type": "string", "minLength": 1 },
    "dedup_key": { "type": "string", "minLength": 1 },
    "changed_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-5][0-9]Z$"
    },
    "causation_ref": {
      "$ref": "https://schemas.shittim.local/common/causation_ref/v2"
    }
  }
}
